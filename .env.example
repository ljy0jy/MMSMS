# DATABASE_URL is the only required value. Upstream URL lives in the
# app_config table (key=upstream_base_url), so updating the TLD doesn't need a
# redeploy; just UPDATE the row in MySQL.
DATABASE_URL=mysql+aiomysql://USER:PASSWORD@HOST:3306/mmsms
UPSTREAM_VERIFY=false
# Outbound proxy provider API (returns "host:port" plain text). Empty = direct.
UPSTREAM_PROXY_API=
